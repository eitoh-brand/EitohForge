EITOHFORGE_APP_NAME=eitohforge-service
EITOHFORGE_APP_ENV=local
EITOHFORGE_LOG_LEVEL=INFO

EITOHFORGE_DB_DRIVER=postgresql+psycopg
EITOHFORGE_DB_HOST=localhost
EITOHFORGE_DB_PORT=5432
EITOHFORGE_DB_USERNAME=postgres
EITOHFORGE_DB_PASSWORD=postgres
EITOHFORGE_DB_NAME=eitohforge
EITOHFORGE_DB_ANALYTICS_ENABLED=false
EITOHFORGE_DB_ANALYTICS_DRIVER=postgresql+psycopg
EITOHFORGE_DB_ANALYTICS_HOST=localhost
EITOHFORGE_DB_ANALYTICS_PORT=5432
EITOHFORGE_DB_ANALYTICS_USERNAME=postgres
EITOHFORGE_DB_ANALYTICS_PASSWORD=postgres
EITOHFORGE_DB_ANALYTICS_NAME=eitohforge_analytics
EITOHFORGE_DB_SEARCH_ENABLED=false
EITOHFORGE_DB_SEARCH_DRIVER=postgresql+psycopg
EITOHFORGE_DB_SEARCH_HOST=localhost
EITOHFORGE_DB_SEARCH_PORT=5432
EITOHFORGE_DB_SEARCH_USERNAME=postgres
EITOHFORGE_DB_SEARCH_PASSWORD=postgres
EITOHFORGE_DB_SEARCH_NAME=eitohforge_search

# Must be at least 32 characters.
EITOHFORGE_AUTH_JWT_SECRET=replace-with-32-plus-char-secret
EITOHFORGE_AUTH_ACCESS_TOKEN_MINUTES=15
EITOHFORGE_AUTH_REFRESH_TOKEN_DAYS=7

EITOHFORGE_CACHE_PROVIDER=redis
EITOHFORGE_CACHE_REDIS_URL=redis://localhost:6379/0
EITOHFORGE_CACHE_DEFAULT_TTL_SECONDS=60

EITOHFORGE_STORAGE_PROVIDER=local
EITOHFORGE_STORAGE_BUCKET_NAME=eitohforge-local-bucket
EITOHFORGE_STORAGE_REGION=us-east-1

EITOHFORGE_SECRET_PROVIDER=env
EITOHFORGE_SECRET_VAULT_MOUNT=secret

# Secret management (Vault KV): set provider + Vault URL.
# EITOHFORGE_SECRET_PROVIDER=vault
# EITOHFORGE_SECRET_VAULT_URL=http://localhost:8200
# VAULT_TOKEN=replace-with-a-real-vault-token

# Realtime WebSocket: set REDIS_URL to fan out broadcasts across Uvicorn workers (optional).
# EITOHFORGE_REALTIME_REDIS_URL=redis://localhost:6379/0
# EITOHFORGE_REALTIME_REDIS_BROADCAST_CHANNEL=eitohforge:realtime:broadcast

# Observability:
# Prometheus (/metrics export, real `prometheus_client`):
# EITOHFORGE_OBSERVABILITY_ENABLE_PROMETHEUS=true
# EITOHFORGE_OBSERVABILITY_PROMETHEUS_METRICS_PATH=/metrics
#
# OTEL traces (OTLP over HTTP, real OpenTelemetry SDK/exporter):
# EITOHFORGE_OBSERVABILITY_OTEL_ENABLED=true
# EITOHFORGE_OBSERVABILITY_OTEL_SERVICE_NAME=eitohforge
# EITOHFORGE_OBSERVABILITY_OTEL_OTLP_HTTP_ENDPOINT=http://localhost:4318/v1/traces
